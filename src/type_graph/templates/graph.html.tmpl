<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>type-graph</title>
<style>
  body { margin: 0; font-family: ui-sans-serif, system-ui, sans-serif; }
  #toolbar { padding: 8px 12px; border-bottom: 1px solid #e5e7eb; display: flex; gap: 8px; align-items: center; }
  #toolbar input, #toolbar select { padding: 4px 6px; }
  #layout { display: flex; height: calc(100vh - 49px); }
  #cy { flex: 1; }
  #inspector { width: 320px; padding: 12px; border-left: 1px solid #e5e7eb; overflow: auto; font-size: 13px; }
  .badge { display: inline-block; padding: 1px 6px; border-radius: 4px; background: #eef2ff; color: #3730a3; font-size: 11px; margin-left: 4px; }
</style>
<script src="https://unpkg.com/cytoscape@3.30.2/dist/cytoscape.min.js"></script>
<script src="https://unpkg.com/dagre@0.8.5/dist/dagre.min.js"></script>
<script src="https://unpkg.com/cytoscape-dagre@2.5.0/cytoscape-dagre.js"></script>
</head>
<body>
<div id="toolbar">
  <input id="search" placeholder="Search name / type / role" size="32">
  <select id="cluster-filter"><option value="">All clusters</option></select>
  <select id="layout-select">
    <option value="dagre">Layout: dagre</option>
    <option value="cose">Layout: cose</option>
  </select>
  <button id="reset">Reset</button>
</div>
<div id="layout">
  <div id="cy"></div>
  <div id="inspector"><em>Click a node.</em></div>
</div>
<script>
const GRAPH = __GRAPH_JSON__;
cytoscape.use(cytoscapeDagre);

function esc(value) {
  return String(value ?? "").replace(/[&<>"']/g, ch => ({
    "&": "&amp;",
    "<": "&lt;",
    ">": "&gt;",
    "\"": "&quot;",
    "'": "&#39;"
  })[ch]);
}

function buildElements(g) {
  const elements = [];
  for (const c of g.clusters) {
    elements.push({ data: { id: "C:" + c.id, label: c.label, summary: c.summary, kind: "cluster" } });
  }
  for (const c of g.clusters) {
    for (const child of c.child_clusters || []) {
      const el = elements.find(e => e.data.id === "C:" + child);
      if (el) el.data.parent = "C:" + c.id;
    }
  }
  for (const f of g.functions) {
    const sig = f.signature || {};
    const params = (sig.params || []).map(p => (p.type || "Any")).join(", ");
    const ret = sig.returns || "Any";
    elements.push({
      data: {
        id: f.id,
        label: f.qualname,
        sigLine: "(" + params + ") → " + ret,
        role: f.role || "",
        role_source: f.role_source || "",
        parent: f.cluster_id ? ("C:" + f.cluster_id) : undefined,
        kind: "function",
        raw: f,
      }
    });
  }
  for (const e of g.edges) {
    const types = (e.passed_types || []).join(", ");
    elements.push({ data: { id: "E:" + e.src + "->" + e.dst + ":" + e.lineno, source: e.src, target: e.dst, label: types, kind: "call" } });
  }
  return elements;
}

const cy = cytoscape({
  container: document.getElementById("cy"),
  elements: buildElements(GRAPH),
  style: [
    { selector: "node[kind = 'cluster']", style: { "shape": "round-rectangle", "background-opacity": 0.04, "border-width": 1, "border-color": "#9ca3af", "label": "data(label)", "text-valign": "top", "text-margin-y": -4, "padding": "12px", "font-size": 12, "color": "#374151" } },
    { selector: "node[kind = 'function']", style: { "shape": "round-rectangle", "background-color": "#eef2ff", "border-width": 1, "border-color": "#6366f1", "label": "data(label)", "text-valign": "center", "font-size": 11, "padding": "6px" } },
    { selector: "edge[kind = 'call']", style: { "curve-style": "bezier", "target-arrow-shape": "triangle", "width": 1, "line-color": "#9ca3af", "target-arrow-color": "#9ca3af", "label": "data(label)", "font-size": 9, "text-background-color": "#fff", "text-background-opacity": 1 } },
    { selector: ".faded", style: { "opacity": 0.15 } },
    { selector: ".highlight", style: { "border-color": "#dc2626", "border-width": 2 } },
  ],
  layout: { name: "dagre", rankDir: "LR" },
});

const insp = document.getElementById("inspector");
cy.on("tap", "node[kind = 'function']", evt => {
  const f = evt.target.data("raw");
  const sig = f.signature || {};
  const params = (sig.params || []).map(p => p.name + ": " + (p.type || "Any")).join(", ");
  insp.innerHTML = `
    <div><strong>${esc(f.qualname)}</strong><span class="badge">${esc(f.role_source)}</span></div>
    <div><code>(${esc(params)}) → ${esc(sig.returns || "Any")}</code></div>
    <div style="margin-top:8px">${f.role ? esc(f.role) : "<em>(no description)</em>"}</div>
    <div style="margin-top:8px"><small>${esc(f.file)}:${esc(f.lineno)}</small></div>
  `;
});

const search = document.getElementById("search");
search.addEventListener("input", () => {
  const q = search.value.trim().toLowerCase();
  cy.batch(() => {
    cy.elements().removeClass("faded highlight");
    if (!q) return;
    cy.nodes("[kind = 'function']").forEach(n => {
      const d = n.data("raw");
      const blob = (d.qualname + " " + (d.role || "") + " " + JSON.stringify(d.signature || {})).toLowerCase();
      if (blob.includes(q)) n.addClass("highlight"); else n.addClass("faded");
    });
  });
});

const cf = document.getElementById("cluster-filter");
for (const c of GRAPH.clusters) {
  const opt = document.createElement("option");
  opt.value = c.id; opt.textContent = c.id;
  cf.appendChild(opt);
}
cf.addEventListener("change", () => {
  const id = cf.value;
  cy.batch(() => {
    cy.elements().removeClass("faded");
    if (!id) return;
    const wanted = new Set([id]);
    cy.nodes("[kind = 'function']").forEach(n => {
      if (!wanted.has(n.data("raw").cluster_id)) n.addClass("faded");
    });
  });
});

document.getElementById("layout-select").addEventListener("change", e => {
  cy.layout({ name: e.target.value, rankDir: "LR" }).run();
});
document.getElementById("reset").addEventListener("click", () => {
  cy.elements().removeClass("faded highlight");
  search.value = ""; cf.value = "";
  cy.fit();
});
</script>
</body>
</html>
